<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation
        duration. -->
        <item name="windowSplashScreenBackground">@color/black</item>

        <!-- Use windowSplashScreenAnimatedIcon to add a drawable or an animated
             drawable. One of these is required. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/todo_splash</item>

        <!-- REMOVE THE ROUNDED ICON BEHAVIOR BY ENSURING NO BACKGROUND IS SET FOR THE ICON ITSELF -->
        <!-- AND PREVENTING THE SYSTEM FROM FORCING A MASK IF POSSIBLE -->
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>

        <!-- Required for animated icons. -->
        <item name="windowSplashScreenAnimationDuration">200</item>

        <!-- Set the theme of the Activity that directly follows your splash
        screen. This is required. -->
        <item name="postSplashScreenTheme">@style/Theme.ToDo</item>
    </style>
    <style name="Theme.ToDo" parent="android:Theme.Material.Light.NoActionBar" />
</resources>